{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/ggplot3scene/scene3d.schema.json",
  "title": "Scene3D v0.1",
  "type": "object",
  "required": ["schemaVersion", "sceneId", "coordinateSystem", "layers", "camera", "axes", "theme", "metadata"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "sceneId": { "type": "string" },
    "coordinateSystem": {
      "type": "object",
      "required": ["type", "handedness", "origin", "originMode", "domain", "aspect"],
      "properties": {
        "type": { "const": "cartesian3d" },
        "handedness": { "const": "right" },
        "origin": { "$ref": "#/$defs/vec3" },
        "originMode": { "enum": ["fixed", "data_min", "data_center"] },
        "domain": { "$ref": "#/$defs/domain3" },
        "aspect": { "type": "object" }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/pointCloudLayer" },
          { "$ref": "#/$defs/polyline3dLayer" },
          { "$ref": "#/$defs/surfaceGridLayer" },
          { "$ref": "#/$defs/surfaceMeshLayer" },
          { "$ref": "#/$defs/contourStackLayer" },
          { "$ref": "#/$defs/ridgelineStackLayer" },
          { "$ref": "#/$defs/faceProjectionLayer" },
          { "$ref": "#/$defs/absAnnotationLayer" }
        ]
      }
    },
    "camera": {
      "type": "object",
      "required": ["projection", "position", "target", "up", "zoom"],
      "properties": {
        "projection": { "enum": ["orthographic", "perspective"] },
        "position": { "$ref": "#/$defs/vec3" },
        "target": { "$ref": "#/$defs/vec3" },
        "up": { "$ref": "#/$defs/vec3" },
        "zoom": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "axes": {
      "type": "object",
      "properties": {
        "grid": {
          "type": "object",
          "properties": {
            "visible": { "type": "boolean" },
            "planes": {
              "type": "array",
              "items": { "enum": ["xy", "xz", "yz"] }
            },
            "domainMode": { "enum": ["full", "positive", "negative", "limits"] },
            "origin": { "$ref": "#/$defs/vec3" },
            "domain": { "$ref": "#/$defs/domain3" },
            "majorBreaks": { "type": "object" }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "lengthFraction": { "type": "number" },
            "arrows": { "type": "boolean" },
            "labels": { "type": "boolean" },
            "titles": { "type": "boolean" }
          }
        },
        "labelPlacement": { "enum": ["auto", "outside", "inside", "none"] },
        "tickPlacement": { "enum": ["auto", "outside", "inside", "none"] }
      }
    },
    "guides": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/colorbarGuide" },
          { "$ref": "#/$defs/legendGuide" }
        ]
      }
    },
    "lights": { "type": "object" },
    "theme": { "type": "object" },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
      "minItems": 3,
      "maxItems": 3
    },
    "domain3": {
      "type": "object",
      "properties": {
        "x": { "$ref": "#/$defs/range2" },
        "y": { "$ref": "#/$defs/range2" },
        "z": { "$ref": "#/$defs/range2" }
      }
    },
    "range2": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "minItems": 2,
      "maxItems": 2
    },
    "pointCloudLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "data", "material"],
      "properties": {
        "type": { "const": "point_cloud" },
        "data": {
          "type": "object",
          "required": ["encoding", "columns"],
          "properties": {
            "encoding": { "const": "json-columns" },
            "columns": {
              "type": "object",
              "required": ["x", "y", "z", "color", "size", "alpha"]
            }
          }
        }
      }
    },
    "surfaceGridLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "data", "material"],
      "properties": {
        "type": { "const": "surface_grid" },
        "data": {
          "type": "object",
          "required": ["kind", "encoding", "x", "y", "z", "shape", "order"],
          "properties": {
            "kind": { "const": "grid2d" },
            "encoding": { "const": "json-grid" },
            "order": { "const": "row-major" },
            "tessellation": { "enum": ["rect", "right1", "right2", "equilateral"] },
            "metadata": {
              "type": "object",
              "properties": {
                "stat": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "enum": ["identity_surface", "function_surface", "density_surface", "smooth_surface"]
                    },
                    "method": { "type": "string" },
                    "gridSize": {
                      "type": "array",
                      "items": { "type": "integer" }
                    },
                    "computedBy": { "const": "R" }
                  }
                }
              }
            },
            "alpha": {
              "anyOf": [
                { "type": "array", "items": { "type": "number" } },
                { "type": "null" }
              ]
            },
            "mask": {
              "anyOf": [
                { "type": "array", "items": { "type": "boolean" } },
                { "type": "null" }
              ]
            },
            "shape": {
              "type": "array",
              "prefixItems": [{ "type": "integer" }, { "type": "integer" }],
              "minItems": 2,
              "maxItems": 2
            }
          }
        }
      }
    },
    "polyline3dLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "space", "data", "style"],
      "properties": {
        "type": { "const": "polyline3d" },
        "space": {
          "type": "object",
          "properties": {
            "type": { "const": "world" }
          }
        },
        "data": {
          "type": "object",
          "required": ["kind", "encoding", "polylines"],
          "properties": {
            "kind": { "const": "polyline3d" },
            "encoding": { "const": "json-polylines" },
            "polylines": {
              "type": "array",
              "items": { "$ref": "#/$defs/polyline3" }
            }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "type": { "enum": ["path", "segment"] },
            "color": { "type": "string" },
            "opacity": { "type": "number" },
            "width": { "type": "number" },
            "widthUnit": { "const": "px" }
          }
        }
      }
    },
    "absAnnotationLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "space", "data", "route", "label", "style"],
      "properties": {
        "type": { "const": "abs_annotation" },
        "space": {
          "type": "object",
          "required": ["type", "units"],
          "properties": {
            "type": { "const": "anchored_billboard" },
            "units": { "const": "px" },
            "depthMode": { "const": "anchor-depth" }
          }
        },
        "occlusion": {
          "type": "object",
          "properties": {
            "anchor": { "enum": ["depth-test", "none"] },
            "leader": { "enum": ["depth-test", "none"] },
            "label": { "enum": ["depth-test", "none"] }
          }
        },
        "visibility": {
          "type": "object",
          "properties": {
            "hideWhenAnchorOutsideFrustum": { "type": "boolean" },
            "hideLeaderWhenAnchorOutsideFrustum": { "type": "boolean" },
            "hideLabelWhenAnchorOutsideFrustum": { "type": "boolean" }
          }
        },
        "data": {
          "type": "object",
          "required": ["encoding", "anchors"],
          "properties": {
            "encoding": { "const": "json-abs" },
            "anchors": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "position", "route", "label"],
                "properties": {
                  "id": { "type": "string" },
                  "position": { "$ref": "#/$defs/vec3" },
                  "route": { "type": "array" },
                  "label": { "type": "object" }
                }
              }
            }
          }
        },
        "route": { "type": "array" },
        "label": { "type": "object" },
        "style": {
          "type": "object",
          "properties": {
            "point": { "type": "object" },
            "line": {
              "type": "object",
              "properties": {
                "widthUnit": { "const": "px" },
                "geometry": { "const": "screen-ribbon" }
              }
            },
            "text": { "type": "object" }
          }
        }
      }
    },
    "surfaceMeshLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "data", "material"],
      "properties": {
        "type": { "const": "surface_mesh" },
        "data": {
          "type": "object",
          "required": ["kind", "encoding", "vertices", "faces", "vertexCount", "faceCount"],
          "properties": {
            "kind": { "const": "mesh3d" },
            "encoding": { "const": "json-mesh" },
            "vertices": { "type": "array", "items": { "type": "number" } },
            "faces": { "type": "array", "items": { "type": "integer" } },
            "vertexCount": { "type": "integer" },
            "faceCount": { "type": "integer" },
            "normals": {
              "anyOf": [
                { "type": "array", "items": { "type": "number" } },
                { "type": "null" }
              ]
            },
            "colors": {
              "anyOf": [
                { "type": "array", "items": { "type": "string" } },
                { "type": "null" }
              ]
            }
          }
        }
      }
    },
    "contourStackLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "space", "data", "style"],
      "properties": {
        "type": { "const": "contour_stack" },
        "space": {
          "type": "object",
          "properties": {
            "type": { "const": "grid_surface" }
          }
        },
        "data": {
          "type": "object",
          "required": ["kind", "encoding", "polylines"],
          "properties": {
            "kind": { "const": "contour_stack" },
            "encoding": { "const": "json-polylines" },
            "polylines": {
              "type": "array",
              "items": { "$ref": "#/$defs/polyline3" }
            }
          }
        },
        "style": { "type": "object" }
      }
    },
    "ridgelineStackLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "space", "data", "style"],
      "properties": {
        "type": { "const": "ridgeline_stack" },
        "space": {
          "type": "object",
          "properties": {
            "type": { "const": "grid_surface" }
          }
        },
        "data": {
          "type": "object",
          "required": ["kind", "encoding", "profiles"],
          "properties": {
            "kind": { "const": "ridgeline_stack" },
            "encoding": { "const": "json-polylines" },
            "profiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/polyline3" }
            }
          }
        },
        "style": { "type": "object" }
      }
    },
    "polyline3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "array", "items": { "type": "number" } },
        "y": { "type": "array", "items": { "type": "number" } },
        "z": { "type": "array", "items": { "type": "number" } },
        "level": {
          "anyOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        }
      }
    },
    "colorbarGuide": {
      "type": "object",
      "required": ["type", "aesthetic", "title", "domain", "palette", "materialMode"],
      "properties": {
        "type": { "const": "colorbar" },
        "aesthetic": { "type": "string" },
        "title": { "type": "string" },
        "domain": { "$ref": "#/$defs/range2" },
        "palette": {
          "type": "array",
          "items": { "type": "string" }
        },
        "materialMode": { "enum": ["unlit", "lit"] }
      }
    },
    "legendGuide": {
      "type": "object",
      "required": ["type", "aesthetic", "title", "entries", "materialMode"],
      "properties": {
        "type": { "const": "legend" },
        "aesthetic": { "type": "string" },
        "title": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "type": "object" }
        },
        "materialMode": { "enum": ["unlit", "lit"] }
      }
    },
    "faceProjectionLayer": {
      "type": "object",
      "required": ["id", "type", "name", "visible", "space", "plane", "axes", "offset", "clip", "data", "style"],
      "properties": {
        "type": { "const": "face_projection" },
        "space": {
          "type": "object",
          "properties": {
            "type": { "const": "face_plane" }
          }
        },
        "plane": {
          "enum": ["xy", "xz", "yz", "zmin", "zmax", "xmin", "xmax", "ymin", "ymax"]
        },
        "axes": {
          "type": "array",
          "items": { "enum": ["x", "y", "z"] },
          "minItems": 2,
          "maxItems": 2
        },
        "offset": { "type": "number" },
        "clip": { "type": "boolean" },
        "data": {
          "type": "object",
          "properties": {
            "kind": { "enum": ["grid2d", "face_points", "face_path", "face_contour"] },
            "encoding": { "enum": ["json-grid", "json-columns", "json-polylines"] },
            "columns": { "type": "object" },
            "polylines": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["x", "y"],
                "properties": {
                  "x": { "type": "array", "items": { "type": "number" } },
                  "y": { "type": "array", "items": { "type": "number" } },
                  "level": {
                    "anyOf": [
                      { "type": "number" },
                      { "type": "null" }
                    ]
                  }
                }
              }
            },
            "order": { "const": "row-major" },
            "tessellation": { "enum": ["rect", "right1", "right2", "equilateral"] }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "type": { "enum": ["density_grid", "points", "path", "contour_lines"] },
            "material": { "enum": ["unlit"] },
            "fill": { "type": "string" },
            "color": { "type": "string" },
            "opacity": { "type": "number" },
            "width": { "type": "number" },
            "widthUnit": { "const": "px" }
          }
        }
      }
    }
  }
}
